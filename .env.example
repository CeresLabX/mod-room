# PostgreSQL connection string (required)
# Example: postgresql://postgres:password@host:5432/modroom
DATABASE_URL=

# Port for the server (Railway sets this automatically)
PORT=3001

# Environment
NODE_ENV=development

# Max upload size in MB
MAX_UPLOAD_SIZE_MB=100

# Upload directory (absolute path recommended in production)
UPLOAD_DIR=./uploads

# Koofr WebDAV root path for library browser (default: /Vectrix/mod)
WEBDAV_ROOT_PATH=/Vectrix/mod
